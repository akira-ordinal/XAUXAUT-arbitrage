# このファイルを .env にコピーして値を設定してください。
# .env は絶対にGitにコミットしないこと(.gitignoreで除外済み)。

# --- Bitget APIキー (DRY_RUN=false で実発注する場合は必須) ---
# 発行時は「先物取引(Trade)」権限のみ付与し、「出金(Withdraw)」権限は絶対に付けないこと。
# 可能であればIPホワイトリストも設定すること。
BITGET_API_KEY=
BITGET_API_SECRET=
BITGET_PASSPHRASE=

# --- 実行モード ---
DRY_RUN=true

# --- 対象シンボル(USDT-M Perpetual Futures) ---
SYMBOL_A=XAUUSDT
SYMBOL_B=XAUTUSDT
PRODUCT_TYPE=USDT-FUTURES
MARGIN_COIN=USDT

# --- 証拠金 / レバレッジ ---
# 事前にBitgetの先物UIで「one-wayモード」に設定しておくこと。
MARGIN_MODE=isolated
LEVERAGE=3

# --- 戦略パラメータ ---
ENTRY_THRESHOLD_PCT=0.0015
EXIT_THRESHOLD_PCT=0.0003
STOP_LOSS_SPREAD_PCT=0.006
MAX_HOLD_SECONDS=21600
TAKER_FEE_PCT=0.0006

# --- サイジング / 運用制限(1脚あたりの想定名目USDT額) ---
TRADE_NOTIONAL_USDT=100
MIN_TRADE_NOTIONAL_USDT=20
MAX_TRADES_PER_DAY=6

# --- 安全装置 ---
MAX_LOSS_USDT=15

# --- サイズ丸め ---
SIZE_DECIMALS_A=2
SIZE_DECIMALS_B=2

# --- cron実行 / 状態保存(相対パスの場合、run_once.pyの実行ディレクトリ基準) ---
STATE_FILE_PATH=state.json
LOCK_FILE_PATH=bot.lock
MAX_RUN_SECONDS=45
TRADE_LOG_PATH=trades.csv
APP_LOG_PATH=bot.log
